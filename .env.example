# Copy to .env and fill in. .env is gitignored.

# --- MQTT (HiveMQ Cloud) ---
# Used by src/main/services/mqtt-client.ts
MQTT_URL=mqtts://your-cluster.s1.eu.hivemq.cloud:8883
MQTT_USER=
MQTT_PASS=

# --- Supabase ---
# Used by src/main/services/supabase.ts
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Anthropic (Claude API) ---
# Used by src/main/services/claude-agent.ts
ANTHROPIC_API_KEY=

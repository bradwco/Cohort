# Copy to .env and fill in. .env is gitignored.

# --- MQTT (HiveMQ Cloud) ---
# Used by src/main/services/mqtt-client.ts
MQTT_URL=mqtts://your-cluster.s1.eu.hivemq.cloud:8883
MQTT_USER=
MQTT_PASS=

# --- Supabase ---
# Used by renderer auth. Vite exposes only VITE_* keys to the desktop UI.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional server/main-process copies for future services.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Anthropic (Claude API) ---
# Used by src/main/services/claude-agent.ts
ANTHROPIC_API_KEY=
